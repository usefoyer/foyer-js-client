{
    "name": "@usefoyer/client",
    "version": "1.0.4",
    "description": "An API client library for the Foyer Client Portal API.",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "build-and-publish": "pnpm build && npm publish",
        "dev": "tsup --watch",
        "test": "vitest run --testTimeout=10000",
        "test:watch": "vitest"
    },
    "keywords": [
        "typescript",
        "library"
    ],
    "author": "Foyer LLC",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/usefoyer/foyer-js-client"
    },
    "bugs": {
        "url": "https://github.com/usefoyer/foyer-js-client/issues"
    },
    "homepage": "https://usefoyer.com",
    "devDependencies": {
        "@types/node": "^22.9.0",
        "@types/uuid": "^10.0.0",
        "dotenv": "^16.3.1",
        "tsup": "^8.3.0",
        "typescript": "^5.6.3",
        "vitest": "^2.1.3"
    },
    "dependencies": {
        "@azure/storage-blob": "^12.25.0",
        "uuid": "^10.0.0"
    },
    "pnpm": {
        "overrides": {
            "esbuild@<=0.24.2": ">=0.25.0",
            "cross-spawn@>=7.0.0 <7.0.5": ">=7.0.5",
            "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
            "nanoid@<3.3.8": ">=3.3.8",
            "glob@>=10.2.0 <10.5.0": ">=10.5.0",
            "fast-xml-parser@>=4.0.0-beta.3 <4.5.5": ">=4.5.5",
            "picomatch@<2.3.2": ">=2.3.2",
            "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
            "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
            "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
            "vite@>=5.0.0 <5.4.21": ">=5.4.21",
            "vite@>=7.0.0 <=7.3.1": ">=7.3.2"
        }
    }
}